COMPOSE_PROJECT_NAME=marketplace

FRONTEND_PORT=3000
STORYBOOK_PORT=6006
WEB_PORT=8080
SWAGGER_UI_PORT=8081
REDOC_PORT=8082
POSTGRES_PORT=5433
PGADMIN_PORT=5050
REDIS_PORT=6381
REVERB_PORT=8083

# Frontend presence heartbeat
NUXT_PUBLIC_PRESENCE_HEARTBEAT_INTERVAL_SECONDS=30
NUXT_PUBLIC_PRESENCE_HEARTBEAT_MAX_BACKOFF_SECONDS=300
NUXT_PUBLIC_PRESENCE_HEARTBEAT_PAUSE_WHEN_HIDDEN=true

# Frontend Reverb/Echo
NUXT_PUBLIC_REVERB_ENABLED=true
NUXT_PUBLIC_REVERB_APP_KEY=local-app-key
NUXT_PUBLIC_REVERB_HOST=localhost
NUXT_PUBLIC_REVERB_PORT=8083
NUXT_PUBLIC_REVERB_SCHEME=http
NUXT_PUBLIC_REVERB_AUTH_ENDPOINT=/broadcasting/auth
